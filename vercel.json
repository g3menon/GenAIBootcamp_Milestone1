{
    "version": 2,
    "builds": [
        {
            "src": "phase5/backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "phase5/frontend/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "phase5/backend/main.py"
        },
        {
            "src": "/api",
            "dest": "phase5/backend/main.py"
        },
        {
            "src": "/",
            "dest": "/phase5/frontend/index.html"
        },
        {
            "src": "/index.html",
            "dest": "/phase5/frontend/index.html"
        },
        {
            "src": "/css/(.*)",
            "dest": "/phase5/frontend/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/phase5/frontend/js/$1"
        },
        {
            "src": "/phase5/frontend/(.*)",
            "dest": "/phase5/frontend/$1"
        }
    ]
}